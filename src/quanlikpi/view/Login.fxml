<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="quanlikpi.presenter.LoginPresenter" prefWidth="400.0" prefHeight="300.0">
    <children>
        <Label text="KPI Management Login">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <VBox spacing="5.0">
            <children>
                <Label text="Username" />
                <TextField fx:id="txtUsername" promptText="Enter username" />
            </children>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label text="Password" />
                <PasswordField fx:id="txtPassword" promptText="Enter password" />
            </children>
        </VBox>
        <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#handleLogin" text="Login" prefWidth="100.0" />
        <Label fx:id="lblMessage" textFill="RED" />
    </children>
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>
</VBox>
