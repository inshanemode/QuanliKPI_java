<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="450.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="quanlikpi.presenter.KPIFormPresenter">
   <children>
      <Label fx:id="lblTitle" text="Add New KPI">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Label text="Assignment:" />
            <RadioButton fx:id="rbIndividual" mnemonicParsing="false" selected="true" text="Individual">
               <toggleGroup>
                  <ToggleGroup fx:id="tgAssignment" />
               </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="rbDepartment" mnemonicParsing="false" text="Department" toggleGroup="$tgAssignment" />
            <Label text="Assign To:" />
            <ComboBox fx:id="cmbAssignee" prefWidth="180.0" />
         </children>
      </HBox>
      <GridPane hgap="10.0" vgap="15.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="120.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="280.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="KPI Name:" />
            <TextField fx:id="txtName" GridPane.columnIndex = "1" />
            <Label text="Target Value:" GridPane.rowIndex="1" />
            <TextField fx:id="txtTarget" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label text="Actual Value:" GridPane.rowIndex="2" />
            <TextField fx:id="txtActual" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label text="Unit:" GridPane.rowIndex="3" />
            <TextField fx:id="txtUnit" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label text="Weight (%):" GridPane.rowIndex="4" />
            <TextField fx:id="txtWeight" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label text="Score:" GridPane.rowIndex="5" />
            <TextField fx:id="txtScore" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <Label text="Status:" GridPane.rowIndex="6" />
            <ComboBox fx:id="cmbStatus" prefWidth="280.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />
         </children>
      </GridPane>
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleCancel" prefWidth="80.0" text="Cancel" />
            <Button mnemonicParsing="false" onAction="#handleSave" prefWidth="80.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Save" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
   </padding>
</VBox>
